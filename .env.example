# UniFi Controller connection
UNIFI_HOST=https://192.168.1.1
UNIFI_SITE=default

# Auth option 1: API key (preferred — create in UniFi OS → Admins → API Keys)
# UNIFI_API_KEY=your-key-here

# Auth option 2: username/password (used if API key is not set)
UNIFI_USERNAME=admin
UNIFI_PASSWORD=changeme

# App settings
PORT=3000
# Optional: restrict to specific filter ID (leave empty to show all)
FILTER_ID=
